# Postgres
DATABASE_URL=postgres://lofify:lofify@postgres:5432/lofify

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=4000
# Secret used to HMAC-sign /play URLs.
PLAYBACK_SIGNING_SECRET=change-me
# Comma-separated origin allowlist for browser CORS. Use `*` to allow any.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Transcode / disk cache
# Max concurrent ffmpeg processes across all transcode requests.
TRANSCODE_MAX_PARALLEL=2
# Soft byte budget for the on-disk transcode cache. Once exceeded, completed entries are evicted
# least-recently-accessed first. Unset = unbounded (no sweeping). The cache dir itself is set by
# DISK_CACHE_DIR (the compose stack mounts it; defaults to the OS tmpdir otherwise).
DISK_CACHE_MAX_BYTES=1073741824
# Cron for the periodic disk-cache sweep. Empty disables the schedule (post-transcode and ENOSPC
# sweeps still run). No effect unless DISK_CACHE_MAX_BYTES is set.
DISK_CACHE_SWEEP_CRON=*/15 * * * *

# Scanner
# Absolute path(s) to music library/ies mounted on the host
LIBRARY_PATH=/music
# Absolute path to mount on the host. Will be mounted at /music on the container
LIBRARY_MOUNT=/music
# Max files parsed and upserted in parallel.
SCAN_CONCURRENCY=4
# Cron expression for the recurring full library scan. Empty disables it.
SCAN_CRON=0 2 * * *

# UI
UI_PORT=5173
# GraphQL endpoint the UI talks to.
VITE_GRAPHQL_URL=http://localhost:4000/graphql
VITE_GRAPHQL_STREAM_URL=http://localhost:4000/graphql/stream

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-lgtm:4318
OTEL_SERVICE_NAME=lofify-backend
OTEL_LOG_LEVEL=info
