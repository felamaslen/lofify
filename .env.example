# Postgres
DATABASE_URL=postgres://lofify:lofify@postgres:5432/lofify

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=4000
# Secret used to HMAC-sign /play URLs.
PLAYBACK_SIGNING_SECRET=change-me

# Playback / transcode
# Max concurrent ffmpeg processes across all transcode requests.
TRANSCODE_MAX_PARALLEL=2
# LRU cache for transcoded streams.
TRANSCODE_CACHE_MAX_BYTES=1073741824
TRANSCODE_CACHE_TTL_SECONDS=3600

# Scanner
# Absolute path to the music library on the host (mounted into scanner container).
LIBRARY_PATH=/music
# Control plane the backend uses to talk to the scanner.
SCANNER_CONTROL_URL=http://scanner:7000

# UI
UI_PORT=5173
# GraphQL endpoint the UI talks to.
VITE_GRAPHQL_URL=http://localhost:4000/graphql
VITE_GRAPHQL_STREAM_URL=http://localhost:4000/graphql/stream

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-lgtm:4318
OTEL_SERVICE_NAME=lofify-backend
OTEL_LOG_LEVEL=info
