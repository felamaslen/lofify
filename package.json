{
  "name": "lofify",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Music player with library scanning, transcoding playback, and a web UI.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "pnpm -r --parallel lint",
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "pnpm -r --parallel test",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "codegen": "pnpm -r --parallel codegen",
    "prepare": "husky",
    "precommit:codegen": "sh scripts/precommit-codegen.sh",
    "db:generate": "pnpm --filter @lofify/backend db:generate",
    "db:migrate": "pnpm --filter @lofify/backend db:migrate",
    "db:migrate:create": "pnpm --filter @lofify/backend db:generate && pnpm --filter @lofify/backend db:migrate:create",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2"
  }
}
