{
  "extends": "../../tsconfig.json",
  "grats": {
    "tsSchema": "src/graphql/__generated__/schema.ts",
    "graphqlSchema": "src/graphql/__generated__/schema.graphql",
    "importModuleSpecifierEnding": ".js",
    "nullableByDefault": false
  },
  "compilerOptions": {
    "types": ["node"],
    "plugins": [
      {
        "name": "@0no-co/graphqlsp",
        "schema": "./src/graphql/__generated__/schema.graphql",
        "tadaOutputLocation": "./src/graphql/__generated__/tada-env.d.ts"
      }
    ]
  },
  "include": ["src"]
}
